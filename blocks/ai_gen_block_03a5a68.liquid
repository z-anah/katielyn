{% doc %}
  @prompt
    Generate a Shopify section block for a "Featured Collections" carousel, as seen in the attached #file:temp.md. The block should:
    
    Display a carousel of product cards, each showing:
    Product image(s) (primary and secondary)
    Product title (linked to product page)
    Badges (e.g., "NEW & EXCLUSIVE", "BEST-SELLER")
    Price
    Quick add button
    (If available) a compact color variant picker as dots
    Include a "SHOP NEW ARRIVALS" button linking to /collections/new-arrivals-2
    Be responsive for mobile, tablet, and desktop (see code for layout details)
    Use semantic HTML and Shopify Liquid where appropriate (e.g., for product loops, images, prices, badges)
    Use BEM or similar class naming for maintainability
    Include any necessary CSS for layout and variant picker styling
    Output only the Shopify section code (Liquid + HTML + CSS), ready to be used in a Shopify theme.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-featured-collections-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-featured-collections__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 32px;
  }

  .ai-featured-collections__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 16px;
    color: {{ block.settings.heading_color }};
  }

  .ai-featured-collections__carousel-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    margin-bottom: 32px;
  }

  .ai-featured-collections__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 4px;
  }

  .ai-featured-collections__track-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-featured-collections__card-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - {{ block.settings.card_gap | times: 3 }}px) / 4);
    min-width: 250px;
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-featured-collections__card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .ai-featured-collections__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 125%;
    overflow: hidden;
    background: #f5f5f5;
  }

  .ai-featured-collections__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.3s ease;
  }

  .ai-featured-collections__image-{{ ai_gen_id }}--secondary {
    opacity: 0;
  }

  .ai-featured-collections__card-{{ ai_gen_id }}:hover .ai-featured-collections__image-{{ ai_gen_id }}--secondary {
    opacity: 1;
  }

  .ai-featured-collections__badge-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    right: 12px;
    background: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 6px 12px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    z-index: 2;
  }

  .ai-featured-collections__info-{{ ai_gen_id }} {
    padding: 16px;
  }

  .ai-featured-collections__product-title-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 500;
    margin: 0 0 8px;
    color: {{ block.settings.text_color }};
    text-decoration: none;
    display: block;
    line-height: 1.4;
  }

  .ai-featured-collections__product-title-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-featured-collections__price-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 12px;
    color: {{ block.settings.price_color }};
  }

  .ai-featured-collections__price-compare-{{ ai_gen_id }} {
    text-decoration: line-through;
    opacity: 0.6;
    margin-right: 8px;
    font-size: 14px;
  }

  .ai-featured-collections__variants-{{ ai_gen_id }} {
    display: flex;
    gap: 6px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }

  .ai-featured-collections__variant-dot-{{ ai_gen_id }} {
    width: {{ block.settings.variant_dot_size }}px;
    height: {{ block.settings.variant_dot_size }}px;
    border-radius: 50%;
    border: 2px solid {{ block.settings.variant_border_color }};
    cursor: pointer;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .ai-featured-collections__variant-dot-{{ ai_gen_id }}:hover {
    transform: scale(1.1);
    border-color: {{ block.settings.variant_border_hover_color }};
  }

  .ai-featured-collections__quick-add-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px;
    background: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-featured-collections__quick-add-{{ ai_gen_id }}:hover {
    background: {{ block.settings.button_hover_background }};
  }

  .ai-featured-collections__cta-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-featured-collections__cta-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 16px 32px;
    background: {{ block.settings.cta_background }};
    color: {{ block.settings.cta_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.cta_border_radius }}px;
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: background 0.3s ease;
  }

  .ai-featured-collections__cta-button-{{ ai_gen_id }}:hover {
    background: {{ block.settings.cta_hover_background }};
  }

  .ai-featured-collections__nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: {{ block.settings.nav_background }};
    color: {{ block.settings.nav_color }};
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: background 0.3s ease;
  }

  .ai-featured-collections__nav-{{ ai_gen_id }}:hover {
    background: {{ block.settings.nav_hover_background }};
  }

  .ai-featured-collections__nav-{{ ai_gen_id }}--prev {
    left: -20px;
  }

  .ai-featured-collections__nav-{{ ai_gen_id }}--next {
    right: -20px;
  }

  @media screen and (max-width: 989px) {
    .ai-featured-collections__card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - {{ block.settings.card_gap | times: 2 }}px) / 3);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-featured-collections__card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - {{ block.settings.card_gap }}px) / 2);
      min-width: 150px;
    }

    .ai-featured-collections__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-featured-collections__nav-{{ ai_gen_id }} {
      display: none;
    }
  }
{% endstyle %}

<featured-collections-{{ ai_gen_id }} class="ai-featured-collections-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <div class="ai-featured-collections__header-{{ ai_gen_id }}">
      <h2 class="ai-featured-collections__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    </div>
  {% endif %}

  <div class="ai-featured-collections__carousel-{{ ai_gen_id }}">
    {% if block.settings.show_navigation %}
      <button class="ai-featured-collections__nav-{{ ai_gen_id }} ai-featured-collections__nav-{{ ai_gen_id }}--prev" aria-label="Previous">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button class="ai-featured-collections__nav-{{ ai_gen_id }} ai-featured-collections__nav-{{ ai_gen_id }}--next" aria-label="Next">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    {% endif %}

    <div class="ai-featured-collections__track-{{ ai_gen_id }}">
      {% if block.settings.collection != blank %}
        {% for product in block.settings.collection.products limit: block.settings.products_to_show %}
          <div class="ai-featured-collections__card-{{ ai_gen_id }}">
            <div class="ai-featured-collections__image-wrapper-{{ ai_gen_id }}">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  loading="lazy"
                  width="600"
                  height="750"
                  class="ai-featured-collections__image-{{ ai_gen_id }}"
                >
              {% endif %}

              {% if product.images[1] and block.settings.show_second_image %}
                <img
                  src="{{ product.images[1] | image_url: width: 600 }}"
                  alt="{{ product.images[1].alt | escape }}"
                  loading="lazy"
                  width="600"
                  height="750"
                  class="ai-featured-collections__image-{{ ai_gen_id }} ai-featured-collections__image-{{ ai_gen_id }}--secondary"
                >
              {% endif %}

              {% if block.settings.show_badges %}
                {% if product.metafields.custom.badge %}
                  <span class="ai-featured-collections__badge-{{ ai_gen_id }}">
                    {{ product.metafields.custom.badge }}
                  </span>
                {% elsif product.available == false %}
                  <span class="ai-featured-collections__badge-{{ ai_gen_id }}">
                    Sold Out
                  </span>
                {% elsif product.compare_at_price > product.price %}
                  <span class="ai-featured-collections__badge-{{ ai_gen_id }}">
                    Sale
                  </span>
                {% endif %}
              {% endif %}
            </div>

            <div class="ai-featured-collections__info-{{ ai_gen_id }}">
              <a href="{{ product.url }}" class="ai-featured-collections__product-title-{{ ai_gen_id }}">
                {{ product.title }}
              </a>

              <div class="ai-featured-collections__price-{{ ai_gen_id }}">
                {% if product.compare_at_price > product.price %}
                  <span class="ai-featured-collections__price-compare-{{ ai_gen_id }}">
                    {{ product.compare_at_price | money }}
                  </span>
                {% endif %}
                <span>{{ product.price | money }}</span>
              </div>

              {% if block.settings.show_color_swatches and product.options_with_values.size > 0 %}
                {% for option in product.options_with_values %}
                  {% assign option_name_downcase = option.name | downcase %}
                  {% if option_name_downcase == 'color' or option_name_downcase == 'colour' %}
                    <div class="ai-featured-collections__variants-{{ ai_gen_id }}">
                      {% for value in option.values limit: 5 %}
                        {% assign color_value = value | downcase | replace: ' ', '-' %}
                        <span
                          class="ai-featured-collections__variant-dot-{{ ai_gen_id }}"
                          style="background-color: {{ color_value }};"
                          title="{{ value }}"
                        ></span>
                      {% endfor %}
                    </div>
                  {% endif %}
                {% endfor %}
              {% endif %}

              {% if block.settings.show_quick_add %}
                <button class="ai-featured-collections__quick-add-{{ ai_gen_id }}" data-product-id="{{ product.id }}">
                  Quick Add
                </button>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      {% else %}
        {% for i in (1..8) %}
          <div class="ai-featured-collections__card-{{ ai_gen_id }}">
            <div class="ai-featured-collections__image-wrapper-{{ ai_gen_id }}">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
            <div class="ai-featured-collections__info-{{ ai_gen_id }}">
              <a href="#" class="ai-featured-collections__product-title-{{ ai_gen_id }}">
                Sample Product {{ i }}
              </a>
              <div class="ai-featured-collections__price-{{ ai_gen_id }}">
                $29.99
              </div>
              {% if block.settings.show_quick_add %}
                <button class="ai-featured-collections__quick-add-{{ ai_gen_id }}">
                  Quick Add
                </button>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>

  {% if block.settings.show_cta_button %}
    <div class="ai-featured-collections__cta-{{ ai_gen_id }}">
      <a href="{{ block.settings.cta_link }}" class="ai-featured-collections__cta-button-{{ ai_gen_id }}">
        {{ block.settings.cta_text }}
      </a>
    </div>
  {% endif %}
</featured-collections-{{ ai_gen_id }}>

<script>
  (function() {
    class FeaturedCollections{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-featured-collections__track-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-featured-collections__nav-{{ ai_gen_id }}--prev');
        this.nextButton = this.querySelector('.ai-featured-collections__nav-{{ ai_gen_id }}--next');
        this.quickAddButtons = this.querySelectorAll('.ai-featured-collections__quick-add-{{ ai_gen_id }}');

        this.setupNavigation();
        this.setupQuickAdd();
      }

      setupNavigation() {
        if (!this.prevButton || !this.nextButton) return;

        this.prevButton.addEventListener('click', () => {
          const scrollAmount = this.track.offsetWidth * 0.8;
          this.track.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
        });

        this.nextButton.addEventListener('click', () => {
          const scrollAmount = this.track.offsetWidth * 0.8;
          this.track.scrollBy({ left: scrollAmount, behavior: 'smooth' });
        });
      }

      setupQuickAdd() {
        this.quickAddButtons.forEach(button => {
          button.addEventListener('click', (e) => {
            const productId = e.target.dataset.productId;
            if (productId) {
              this.addToCart(productId);
            }
          });
        });
      }

      addToCart(productId) {
        fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            id: productId,
            quantity: 1
          })
        })
        .then(response => response.json())
        .then(data => {
          window.dispatchEvent(new CustomEvent('cart:refresh'));
        })
        .catch(error => {
          console.error('Error adding to cart:', error);
        });
      }
    }

    customElements.define('featured-collections-{{ ai_gen_id }}', FeaturedCollections{{ ai_gen_id }});
  })();
</script>

