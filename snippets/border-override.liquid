{%- comment -%}
  Renders border override CSS
{%- endcomment -%}

{% comment %}
  build a style string from section.settings.
  existing code may already handle `border`, `border_width`,
  `border_opacity` and `border_radius`.
  extend it with vertical/horizontal controls.
{% endcomment %}

{% assign opacity = settings.border_opacity | default: 100 | times: 0.01 %}

{% if settings.border != 'none' %}
  border: {{ settings.border_width }}px {{ settings.border }}
    rgba(var(--color-border-rgb), {{ opacity }});
{% endif %}

{% if settings.border_vertical != 'none' %}
  border-left: {{ settings.border_vertical_width }}px
    {{ settings.border_vertical }}
    rgba(var(--color-border-rgb), {{ opacity }});
  border-right: {{ settings.border_vertical_width }}px
    {{ settings.border_vertical }}
    rgba(var(--color-border-rgb), {{ opacity }});
{% endif %}

{% if settings.border_horizontal != 'none' %}
  border-top: {{ settings.border_horizontal_width }}px
    {{ settings.border_horizontal }}
    rgba(var(--color-border-rgb), {{ opacity }});
  border-bottom: {{ settings.border_horizontal_width }}px
    {{ settings.border_horizontal }}
    rgba(var(--color-border-rgb), {{ opacity }});
{% endif %}

{% if settings.border_radius %}
  border-radius: {{ settings.border_radius }}px;
{% endif %}
