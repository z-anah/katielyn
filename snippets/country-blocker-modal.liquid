<div id="country-overlay" style="display:none;">
  <div id="country-modal">
    <h2>We don’t ship to Indonesia</h2>
    <p>Please select your shipping country.</p>

    {% form 'localization' %}
      <input type="hidden" name="return_to" value="{{ request.path }}">

      <select name="country_code" required>
        <option value="AU">Australia ($)</option>
        <option value="SG">Singapore ($)</option>
        <option value="US">United States ($)</option>
      </select>

      <button type="submit">Shop Now</button>
    {% endform %}
  </div>
</div>

<script>
(async function () {
  try {
    // If user already chose a country, do nothing
    const savedCountry = localStorage.getItem('selectedCountry');
    if (savedCountry) return;

    // Detect real IP country
    const res = await fetch('https://ipapi.co/json/');
    const data = await res.json();

    // Show popup only for Indonesia
    if (data && data.country === 'ID') {
      document.getElementById('country-overlay').style.display = 'flex';
    }

    // Save chosen country on submit
    document.addEventListener('submit', function (e) {
      const form = e.target.closest('#country-modal form');
      if (!form) return;

      const select = form.querySelector('select[name="country_code"]');
      if (select && select.value) {
        localStorage.setItem('selectedCountry', select.value);
      }
    });

  } catch (e) {
    console.error('Country selection error');
  }
})();
</script>
