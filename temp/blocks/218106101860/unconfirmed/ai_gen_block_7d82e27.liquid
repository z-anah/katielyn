{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-scrolling-text-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    overflow: hidden;
    position: relative;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.vertical_padding }}px 0;
  }

  .ai-scrolling-text-container-{{ ai_gen_id }} {
    display: flex;
    position: relative;
    width: 100%;
  }

  .ai-scrolling-text-item-{{ ai_gen_id }} {
    display: flex;
    white-space: nowrap;
    animation: ai-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
    {% if block.settings.direction == 'right' %}
      animation-direction: reverse;
    {% endif %}
  }

  .ai-scrolling-text-item-{{ ai_gen_id }}:nth-child(n+2) {
    position: absolute;
    top: 0;
  }

  .ai-scrolling-text-item-{{ ai_gen_id }}:nth-child(2) {
    left: 100%;
  }

  .ai-scrolling-text-item-{{ ai_gen_id }}:nth-child(3) {
    left: 200%;
  }

  .ai-scrolling-text-item-{{ ai_gen_id }}:nth-child(4) {
    left: 300%;
  }

  .ai-scrolling-text-item-{{ ai_gen_id }}:nth-child(5) {
    left: 400%;
  }

  .ai-scrolling-text-item-{{ ai_gen_id }}:nth-child(6) {
    left: 500%;
  }

  .ai-scrolling-text-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.font_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    padding: 0 {{ block.settings.text_spacing }}px;
    font-weight: {{ block.settings.font_weight }};
    {% if block.settings.text_transform == 'uppercase' %}
      text-transform: uppercase;
    {% endif %}
  }

  @keyframes ai-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-100%);
    }
  }

  @media (hover: hover) {
    .ai-scrolling-text-{{ ai_gen_id }}:hover .ai-scrolling-text-item-{{ ai_gen_id }} {
      {% if block.settings.pause_on_hover %}
        animation-play-state: paused;
      {% endif %}
    }
  }

  @media screen and (max-width: 749px) {
    .ai-scrolling-text-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.7 }}px;
    }
  }
{% endstyle %}

<scrolling-text-{{ ai_gen_id }} class="ai-scrolling-text-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-scrolling-text-container-{{ ai_gen_id }}">
    {% for i in (1..6) %}
      <div class="ai-scrolling-text-item-{{ ai_gen_id }}" {% if i > 1 %}aria-hidden="true"{% endif %}>
        {% for j in (1..block.settings.repeat_count) %}
          <p class="ai-scrolling-text-text-{{ ai_gen_id }}">
            {{ block.settings.text }}
          </p>
        {% endfor %}
      </div>
    {% endfor %}
  </div>
</scrolling-text-{{ ai_gen_id }}>

<script>
  (function() {
    class ScrollingText{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.adjustScrollSpeed();
      }

      adjustScrollSpeed() {
        const container = this.querySelector('.ai-scrolling-text-container-{{ ai_gen_id }}');
        const firstItem = this.querySelector('.ai-scrolling-text-item-{{ ai_gen_id }}');
        
        if (!container || !firstItem) return;

        const containerWidth = container.offsetWidth;
        const itemWidth = firstItem.offsetWidth;

        if (itemWidth < containerWidth) {
          const repeatCount = Math.ceil(containerWidth / itemWidth) + 2;
          const items = this.querySelectorAll('.ai-scrolling-text-item-{{ ai_gen_id }}');
          
          items.forEach((item, index) => {
            if (index > 0) {
              item.style.left = (index * 100) + '%';
            }
          });
        }
      }
    }

    customElements.define('scrolling-text-{{ ai_gen_id }}', ScrollingText{{ ai_gen_id }});
  })();
</script>

