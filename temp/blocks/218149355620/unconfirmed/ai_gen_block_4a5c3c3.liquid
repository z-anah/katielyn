{% doc %}
  @prompt
    Generate a Shopify section block for a "Featured Collections" carousel, as seen in the attached #file:temp.md. The block should:
    
    Display a carousel of product cards, each showing:
    Product image(s) (primary and secondary)
    Product title (linked to product page)
    Badges (e.g., "NEW & EXCLUSIVE", "BEST-SELLER")
    Price
    Quick add button
    (If available) a compact color variant picker as dots
    Include a "SHOP NEW ARRIVALS" button linking to /collections/new-arrivals-2
    Be responsive for mobile, tablet, and desktop (see code for layout details)
    Use semantic HTML and Shopify Liquid where appropriate (e.g., for product loops, images, prices, badges)
    Use BEM or similar class naming for maintainability
    Include any necessary CSS for layout and variant picker styling
    Output only the Shopify section code (Liquid + HTML + CSS), ready to be used in a Shopify theme.
    
    **Style Summary:**
    
    - **Typography:**  
      - Section heading uses uppercase, bold, and large font for "NEW ARRIVALS".
      - Subheading "SHOP OUR" is smaller and regular weight.
      - Product titles are uppercase, spaced, and centered.
      - Prices are bold and centered.
    
    - **Layout:**  
      - Clean, minimal, and spacious with generous padding.
      - Products are displayed in a horizontal scrollable carousel/grid.
      - Each product card has a thin border.
      - Section has a border at the top and bottom.
    
    - **Product Card:**  
      - Large product images with aspect ratio preserved.
      - Badges (e.g., "NEW & EXCLUSIVE") appear at the top left of images.
      - Quick add button overlays the image.
      - Variant color dots are shown below the price.
      - All elements are vertically stacked and centered.
    
    - **Button:**  
      - "SHOP NEW ARRIVALS" button is centered, outlined, and uses uppercase bold text.
    
    - **Colors:**  
      - Neutral background (off-white/light grey).
      - Black text and borders.
      - Badge uses a light grey background with dark text.
      - Variant dots use product colors.
    
    - **Responsiveness:**  
      - Layout adapts for mobile, tablet, and desktop.
      - Product cards resize and reflow based on screen size.
    
    - **Overall:**  
      - Modern, minimal, and editorial with strong visual hierarchy and focus on product imagery.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-featured-collections-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    border-top: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-featured-collections__container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-featured-collections__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-featured-collections__subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: {{ block.settings.text_color }};
    margin: 0 0 8px;
  }

  .ai-featured-collections__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-featured-collections__carousel-{{ ai_gen_id }} {
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    margin-bottom: {{ block.settings.carousel_spacing }}px;
  }

  .ai-featured-collections__carousel-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-featured-collections__grid-{{ ai_gen_id }} {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax({{ block.settings.card_width_mobile }}px, 1fr);
    gap: {{ block.settings.card_gap }}px;
    padding: 10px 0;
  }

  .ai-featured-collections__card-{{ ai_gen_id }} {
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    background-color: {{ block.settings.card_background }};
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .ai-featured-collections__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
  }

  .ai-featured-collections__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.3s ease;
  }

  .ai-featured-collections__image-{{ ai_gen_id }}--secondary {
    opacity: 0;
  }

  .ai-featured-collections__card-{{ ai_gen_id }}:hover .ai-featured-collections__image-{{ ai_gen_id }}--secondary {
    opacity: 1;
  }

  .ai-featured-collections__badge-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    left: 12px;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 6px 12px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1px;
    z-index: 2;
  }

  .ai-featured-collections__quick-add-{{ ai_gen_id }} {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    background-color: {{ block.settings.quick_add_background }};
    color: {{ block.settings.quick_add_text_color }};
    border: {{ block.settings.quick_add_border_width }}px solid {{ block.settings.quick_add_border_color }};
    padding: 10px 24px;
    font-size: {{ block.settings.quick_add_font_size }}px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.3s ease, background-color 0.3s ease;
    z-index: 2;
    white-space: nowrap;
  }

  .ai-featured-collections__card-{{ ai_gen_id }}:hover .ai-featured-collections__quick-add-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-featured-collections__quick-add-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.quick_add_hover_background }};
    color: {{ block.settings.quick_add_hover_text_color }};
  }

  .ai-featured-collections__info-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-featured-collections__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: {{ block.settings.text_color }};
    margin: 0;
    text-decoration: none;
    display: block;
  }

  .ai-featured-collections__title-{{ ai_gen_id }}:hover {
    color: {{ block.settings.text_color }};
  }

  .ai-featured-collections__price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
  }

  .ai-featured-collections__variants-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .ai-featured-collections__variant-dot-{{ ai_gen_id }} {
    width: {{ block.settings.variant_dot_size }}px;
    height: {{ block.settings.variant_dot_size }}px;
    border-radius: 50%;
    border: 1px solid {{ block.settings.card_border_color }};
    cursor: pointer;
    transition: transform 0.2s ease;
  }

  .ai-featured-collections__variant-dot-{{ ai_gen_id }}:hover {
    transform: scale(1.2);
  }

  .ai-featured-collections__cta-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-featured-collections__button-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.cta_background }};
    color: {{ block.settings.cta_text_color }};
    border: {{ block.settings.cta_border_width }}px solid {{ block.settings.cta_border_color }};
    padding: 14px 40px;
    font-size: {{ block.settings.cta_font_size }}px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    text-decoration: none;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  .ai-featured-collections__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_hover_background }};
    color: {{ block.settings.cta_hover_text_color }};
  }

  .ai-featured-collections__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.text_color }};
    font-size: 14px;
  }

  @media screen and (min-width: 750px) {
    .ai-featured-collections__grid-{{ ai_gen_id }} {
      grid-auto-columns: minmax({{ block.settings.card_width_tablet }}px, 1fr);
    }

    .ai-featured-collections__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 1.2 }}px;
    }

    .ai-featured-collections__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 1.2 }}px;
    }
  }

  @media screen and (min-width: 990px) {
    .ai-featured-collections__grid-{{ ai_gen_id }} {
      grid-auto-columns: minmax({{ block.settings.card_width_desktop }}px, 1fr);
    }

    .ai-featured-collections__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 1.4 }}px;
    }

    .ai-featured-collections__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 1.5 }}px;
    }
  }
{% endstyle %}

<featured-collections-{{ ai_gen_id }} class="ai-featured-collections-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-featured-collections__container-{{ ai_gen_id }}">
    {% if block.settings.show_header %}
      <div class="ai-featured-collections__header-{{ ai_gen_id }}">
        {% if block.settings.subheading != blank %}
          <div class="ai-featured-collections__subheading-{{ ai_gen_id }}">
            {{ block.settings.subheading }}
          </div>
        {% endif %}
        {% if block.settings.heading != blank %}
          <h2 class="ai-featured-collections__heading-{{ ai_gen_id }}">
            {{ block.settings.heading }}
          </h2>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.collection != blank %}
      <div class="ai-featured-collections__carousel-{{ ai_gen_id }}">
        <div class="ai-featured-collections__grid-{{ ai_gen_id }}">
          {% for product in block.settings.collection.products limit: block.settings.products_to_show %}
            <div class="ai-featured-collections__card-{{ ai_gen_id }}">
              <div class="ai-featured-collections__image-wrapper-{{ ai_gen_id }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 800 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    loading="lazy"
                    width="800"
                    height="{{ 800 | times: block.settings.image_aspect_ratio | divided_by: 100 }}"
                    class="ai-featured-collections__image-{{ ai_gen_id }}"
                  >
                  {% if product.images[1] and block.settings.show_second_image %}
                    <img
                      src="{{ product.images[1] | image_url: width: 800 }}"
                      alt="{{ product.images[1].alt | escape }}"
                      loading="lazy"
                      width="800"
                      height="{{ 800 | times: block.settings.image_aspect_ratio | divided_by: 100 }}"
                      class="ai-featured-collections__image-{{ ai_gen_id }} ai-featured-collections__image-{{ ai_gen_id }}--secondary"
                    >
                  {% endif %}
                {% else %}
                  <div class="ai-featured-collections__image-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}

                {% if block.settings.show_badges %}
                  {% if product.tags contains 'new' or product.tags contains 'NEW' %}
                    <div class="ai-featured-collections__badge-{{ ai_gen_id }}">
                      {{ block.settings.new_badge_text }}
                    </div>
                  {% elsif product.tags contains 'bestseller' or product.tags contains 'best-seller' %}
                    <div class="ai-featured-collections__badge-{{ ai_gen_id }}">
                      {{ block.settings.bestseller_badge_text }}
                    </div>
                  {% endif %}
                {% endif %}

                {% if block.settings.show_quick_add %}
                  <button
                    class="ai-featured-collections__quick-add-{{ ai_gen_id }}"
                    data-product-id="{{ product.id }}"
                    data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                  >
                    {{ block.settings.quick_add_text }}
                  </button>
                {% endif %}
              </div>

              <div class="ai-featured-collections__info-{{ ai_gen_id }}">
                <a
                  href="{{ product.url }}"
                  class="ai-featured-collections__title-{{ ai_gen_id }}"
                >
                  {{ product.title }}
                </a>

                <div class="ai-featured-collections__price-{{ ai_gen_id }}">
                  {{ product.price | money }}
                </div>

                {% if block.settings.show_color_variants and product.options_with_values.size > 0 %}
                  {% for option in product.options_with_values %}
                    {% assign option_name_downcase = option.name | downcase %}
                    {% if option_name_downcase == 'color' or option_name_downcase == 'colour' %}
                      <div class="ai-featured-collections__variants-{{ ai_gen_id }}">
                        {% for value in option.values limit: block.settings.max_color_variants %}
                          {% assign color_value = value | downcase | replace: ' ', '-' %}
                          <span
                            class="ai-featured-collections__variant-dot-{{ ai_gen_id }}"
                            style="background-color: {{ color_value }};"
                            title="{{ value }}"
                          ></span>
                        {% endfor %}
                      </div>
                    {% endif %}
                  {% endfor %}
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      </div>

      {% if block.settings.show_cta %}
        <div class="ai-featured-collections__cta-{{ ai_gen_id }}">
          <a
            href="{{ block.settings.cta_link }}"
            class="ai-featured-collections__button-{{ ai_gen_id }}"
          >
            {{ block.settings.cta_text }}
          </a>
        </div>
      {% endif %}
    {% else %}
      <div class="ai-featured-collections__empty-state-{{ ai_gen_id }}">
        Select a collection to display products
      </div>
    {% endif %}
  </div>
</featured-collections-{{ ai_gen_id }}>

<script>
  (function() {
    class FeaturedCollections{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.quickAddButtons = this.querySelectorAll('.ai-featured-collections__quick-add-{{ ai_gen_id }}');
        this.setupQuickAdd();
      }

      setupQuickAdd() {
        this.quickAddButtons.forEach((button) => {
          button.addEventListener('click', (e) => {
            e.preventDefault();
            const variantId = button.dataset.variantId;
            
            if (variantId) {
              const formData = {
                items: [{
                  id: variantId,
                  quantity: 1
                }]
              };

              fetch('/cart/add.js', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                },
                body: JSON.stringify(formData)
              })
              .then(response => response.json())
              .then(data => {
                button.textContent = 'Added!';
                setTimeout(() => {
                  button.textContent = '{{ block.settings.quick_add_text }}';
                }, 2000);
                
                if (window.theme && window.theme.cart) {
                  window.theme.cart.refresh();
                }
                
                document.dispatchEvent(new CustomEvent('cart:refresh'));
              })
              .catch((error) => {
                console.error('Error:', error);
                button.textContent = 'Error';
                setTimeout(() => {
                  button.textContent = '{{ block.settings.quick_add_text }}';
                }, 2000);
              });
            }
          });
        });
      }
    }

    customElements.define('featured-collections-{{ ai_gen_id }}', FeaturedCollections{{ ai_gen_id }});
  })();
</script>

